# Get a free Postgres connection string from Neon (neon.tech) or Supabase (supabase.com).
#
# Neon gives you two versions of the same connection string in its "Connect"
# modal — they differ only by "-pooler" in the hostname:
#   DATABASE_URL: the POOLED one (has "-pooler" in the hostname). The app
#                 uses this for normal day-to-day queries.
#   DIRECT_URL:   the DIRECT one (no "-pooler"). Prisma's migration commands
#                 (prisma migrate, prisma db push) use this instead — Neon's
#                 pooler can't handle the kind of multi-statement operation a
#                 migration needs and will drop the connection mid-way.
# If you're on Supabase instead, it also provides both a pooled ("Transaction"
# or "Session" mode) and a direct connection string in its Connect dialog —
# use the same split.
DATABASE_URL="postgresql://user:password@host-pooler:5432/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Any long random string — used to sign login tokens.
JWT_SECRET="change-this-to-a-long-random-string"

# Comma-separated list of frontend origins allowed to call this API.
CORS_ORIGIN="http://localhost:5173"

PORT=4000
