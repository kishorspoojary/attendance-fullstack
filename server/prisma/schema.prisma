// ============================================================================
// PRISMA SCHEMA — the blueprint for every table in the database.
//
// If you've never seen Prisma before: each "model" below becomes a real
// database table. Prisma reads this file and generates JavaScript functions
// (like `prisma.student.create(...)`) that we use everywhere in server/src.
//
// Quick vocabulary:
//   @id           → this field is the table's primary key
//   @default(...) → the value a field gets if you don't supply one
//   @unique       → no two rows may share this value
//   @relation     → this field links to a row in another table (a foreign key)
//   String?       → the "?" means this field is optional (can be null)
//   Json          → a flexible field holding any JSON, for small nested data
//
// IMPORTANT MODELING NOTE — there are two unrelated "floor" concepts in this
// app, and this schema keeps them as two separate models on purpose:
//   - CollegeFloor: a floor of the academic building. Holds Classrooms.
//     Discipline Officers and Incharge Teachers are assigned to a
//     CollegeFloor (pooled — several staff can share one).
//   - HostelFloor: a floor of a specific Hostel. Holds HostelRooms.
//     Wardens are assigned directly to HostelRooms, not to a HostelFloor.
// Never merge these into one "Floor" model — a Warden's rooms and a DO's
// floor are genuinely different hierarchies (Hostel → Floor → Room vs.
// College → Floor → Classroom) even though people casually call both "floor."
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  PRINCIPAL
  AO
  COORDINATOR
  DB_MANAGER
  WARDEN
  DO
  INCHARGE_TEACHER
  LAI
}

// An account's lifecycle. Every non-Principal account is created by someone
// else, so it needs a state beyond a simple on/off switch:
//   PENDING  → DB Manager proposed this staff account; waiting on AO approval
//   ACTIVE   → can log in normally
//   FROZEN   → AO paused this account; cannot log in until unfrozen
//   REJECTED → AO declined the account request; cannot log in, kept for record
enum AccountStatus {
  PENDING
  ACTIVE
  FROZEN
  REJECTED
}

// Every person who can log in — one table for all eight roles, distinguished
// by the `role` field. Login is by `loginKey` + password, not username —
// there is no username field in this app at all.
//
// loginKey and passwordHash split two different jobs that used to blur
// together: loginKey is a permanent, non-secret identifier — set once at
// creation by whoever creates the account, never reset, safe to display in
// plain text. passwordHash is the actual credential — an authority never
// chooses it directly, only ever a generated temp value (account creation,
// or Reset Password) that the owner must replace with one only they know.
model User {
  id              String        @id @default(cuid())
  name            String
  loginKey        String        @unique // 4-digit numeric string, e.g. "4821" — see auth.js keygen. Permanent — no reset flow.
  passwordHash    String // bcrypt hash of the real secret — starts as a generated temp password, never a shared constant
  mustSetPassword Boolean       @default(true) // true while still on a generated temp password (fresh creation or after Reset Password) — cleared once the owner sets their own
  role            Role
  status          AccountStatus @default(ACTIVE) // Principal + leadership start ACTIVE; DB-Manager-created staff start PENDING
  createdAt       DateTime      @default(now())

  // Scope of responsibility — which fields matter depends on the role:
  roomIds  Json @default("[]") // Warden: HostelRoom ids they cover
  floorIds Json @default("[]") // DO / Incharge Teacher: CollegeFloor ids they cover (pooled)
  classIds Json @default("[]") // LAI: Classroom ids they cover

  pendingChanges PendingChange[]
}

// ---------------------------------------------------------------- Hostel side
model Hostel {
  id     String        @id @default(cuid())
  name   String
  floors HostelFloor[]
}

model HostelFloor {
  id       String       @id @default(cuid())
  name     String
  hostelId String
  hostel   Hostel       @relation(fields: [hostelId], references: [id])
  rooms    HostelRoom[]
}

model HostelRoom {
  id            String      @id @default(cuid())
  roomNo        String
  hostelFloorId String
  hostelFloor   HostelFloor @relation(fields: [hostelFloorId], references: [id])
  students      Student[]
}

// ---------------------------------------------------------------- College side
model CollegeFloor {
  id         String      @id @default(cuid())
  name       String
  classrooms Classroom[]
}

// "Classroom" is what the code calls it; to staff this is a "class" or
// "batch" — interchangeable words for the same thing, not two concepts.
model Classroom {
  id             String             @id @default(cuid())
  name           String
  collegeFloorId String
  collegeFloor   CollegeFloor       @relation(fields: [collegeFloorId], references: [id])
  students       Student[]
  attendanceRecords AttendanceRecord[]
}

model Student {
  id      String      @id @default(cuid())
  name    String
  roll    String
  classId String
  class   Classroom   @relation(fields: [classId], references: [id])
  roomId  String? // null means "day scholar" — no hostel room
  room    HostelRoom? @relation(fields: [roomId], references: [id])

  // Explicit "local student" (day scholar) tag. Kept as its own field rather
  // than just inferring it from roomId being empty, because it decides who's
  // responsible for this student day to day: a Local Attendance Incharge for
  // local students, a Warden for hostellers. applyChange.js defaults it from
  // roomId when a Database Manager doesn't set it explicitly (no room = local).
  isLocal Boolean @default(true)

  // Persistent "away" status (e.g. went home). Once a Warden sets this, the
  // student counts as absent automatically every day — no re-marking needed —
  // until a Warden clears it via the "report back" action.
  awayReason String?
  awaySince  String?
}

// The Database Manager never edits students/rooms/staff/hostels directly.
// Every edit becomes a row here with status "pending", and only takes real
// effect once an AO approves it (see applyChange.js). This is the two-person
// control the workflow calls for, and it's also how new staff accounts
// (Warden/LAI/DO/Incharge Teacher) get created — see type "create_staff".
model PendingChange {
  id            String   @id @default(cuid())
  // e.g. "add_student", "create_staff", "bulk_add_students" — see applyChange.js.
  // "structure_batch" is the one type that bundles many creates (hostels ->
  // floors -> rooms, college floors -> classrooms) into a single row instead
  // of one PendingChange per item — see structureBatch.js and applyChange.js.
  type          String
  summary       String // short human-readable description shown in the AO's queue
  payload       Json // the data needed to apply the change; shape depends on `type`
  requestedById String
  requestedBy   User     @relation(fields: [requestedById], references: [id])
  // pending | approved | rejected | sent_back (sent_back is structure_batch-only —
  // see routes/structure.js; other types only ever get approved/rejected)
  status        String   @default("pending")
  reason        String? // why an AO rejected it, or why a structure_batch was sent back for edits
  createdAt     DateTime @default(now())
}

// One row per classroom per day — the heart of the daily workflow. The chain
// is exactly three stages now (AO does not approve daily attendance):
//   doApproved  →  teacherApproved  →  coordinatorApproved  →  published
// Each *Approved field holds a small object like
// { by: "userId", byName: "Priya", at: "2026-07-04T09:15:00.000Z" }, or stays
// null until that stage happens.
//
// The DO's own work happens in two separate windows, at two different
// times of day, because a DO walking into a classroom mid-period can check
// who's physically absent right then, but can't phone anyone's home or
// warden until later:
//   Window 1 (in the classroom): headcount + doConfirmed — "yes, this
//     student really is absent" (or correct-presence, if they're not).
//   Window 2 (later, on the phone): doVerified — the actual reason, only
//     settable once a student is doConfirmed. See routes/attendance.js.
model AttendanceRecord {
  id      String    @id @default(cuid())
  date    String // "YYYY-MM-DD"
  classId String
  class   Classroom @relation(fields: [classId], references: [id])

  headcount      Int? // physical count the DO enters before they can approve
  wardenAbsences Json @default("{}") // { studentId: {by, byName, at, reason} }
  laiAbsences    Json @default("{}") // { studentId: {by, byName, at, reason: null} } — LAI never sets a reason

  doConfirmed Json @default("{}") // { studentId: {by, byName, at} } — Window 1: confirmed absent in the classroom
  doVerified  Json @default("{}") // { studentId: {reason, verifiedBy, verifiedByName, at} } — Window 2: reason after calling

  doApproved          Json?
  teacherApproved      Json?
  coordinatorApproved Json?

  // If the deadline passes before every stage is done, Coordinator's cutoff
  // action can force this record to "publish" anyway — but never bypasses
  // the DO stage (see routes/attendance.js). skippedStages then records
  // exactly which later stage(s) were skipped.
  forcedPublish Boolean @default(false)
  skippedStages Json    @default("[]")

  // Send-back: when a stage (DO/Teacher/Coordinator) rejects what's in front
  // of them instead of approving it, this records why, so whoever receives
  // it understands the problem. Cleared once the record moves forward again.
  // { fromStage, fromName, toStage, reason, at }
  sentBack Json?

  @@unique([date, classId])
}
